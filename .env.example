# ============================================================
# Variables de entorno para Vercel
# Configúralas en: vercel.com → tu proyecto → Settings → Environment Variables
# ============================================================

# Base de datos (usa Neon.tech gratis para PostgreSQL en producción)
# https://neon.tech → crear proyecto → copiar connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Seguridad JWT — cambia esto por una cadena aleatoria larga
SECRET_KEY=cambia-esto-por-algo-muy-secreto-2026

# Groq API (IA principal — 14,400 req/día gratis)
# https://console.groq.com/keys
GROQ_API_KEY=gsk_...
GROQ_MODEL=qwen/qwen3-32b

# Google Gemini (fallback — 1,500 req/día gratis)
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# App
APP_NAME=NeuroLearn AI
APP_VERSION=1.0.0
DEBUG=false
